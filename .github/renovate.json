{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "rebaseWhen": "behind-base-branch",
  "commitMessagePrefix": "[renovatebot] ",
  "postUpdateOptions": ["yarnDedupeHighest"],
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "additionalBranchPrefix": "{{#if (or (equals newVersionAgeInDays 0) (equals newVersionAgeInDays 1) (equals newVersionAgeInDays 2) (equals newVersionAgeInDays 3))}}new--{{/if}}",
  "gitlabci": {
    "managerFilePatterns": ["/\\.gitlab-ci\\.ya?ml$/", "/gitlab-ci\\.ya?ml$/"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "node",
      "matchPackageNames": ["node", "@types/node", "actions/node-versions"]
    },
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "deps",
      "matchPackageNames": [
        "!/^typescript$/",
        "!/^node$/",
        "!/^@types\\/node$/",
        "!/^actions\\/node-versions$/"
      ]
    }
  ]
}
